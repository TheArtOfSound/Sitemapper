{
  "name": "sitemapper",
  "version": "0.1.0",
  "description": "Generate public searchable site indexes from sitemap.xml, with built-in SEO and crawlability checks.",
  "type": "module",
  "bin": {
    "sitemapper": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:worker": "tsc -p tsconfig.worker.json",
    "deploy:worker": "npm run build:worker && wrangler deploy",
    "dev": "tsx src/cli.ts",
    "dev:worker": "npm run build:worker && wrangler dev",
    "test": "vitest run",
    "test:live": "SITEMAPPER_LIVE=1 vitest run src/test/live.test.ts",
    "check": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.worker.json --noEmit"
  },
  "keywords": [
    "sitemap",
    "seo",
    "crawlability",
    "site-index",
    "static-site",
    "robots-txt"
  ],
  "author": "TheArtOfSound",
  "license": "MIT",
  "dependencies": {
    "cheerio": "^1.0.0",
    "commander": "^12.1.0",
    "fast-xml-parser": "^4.5.0",
    "p-limit": "^6.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260601.0",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "wrangler": "^4.99.0"
  },
  "engines": {
    "node": ">=20"
  }
}
