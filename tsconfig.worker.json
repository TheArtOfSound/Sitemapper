{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2022", "WebWorker"],
    "types": ["@cloudflare/workers-types"],
    "outDir": "worker-dist",
    "rootDir": ".",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmitOnError": true
  },
  "include": ["worker/**/*.ts", "src/types.ts", "src/utils/url.ts"]
}
